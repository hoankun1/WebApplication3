@model IEnumerable<WebApplication3.Models.CartItem>

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container mt-4">

    ```
    <h2 class="mb-4">
        🛒 Giỏ hàng của bạn
    </h2>

    @if (Model.Any())
    {
        <div class="card shadow border-0">

            <div class="card-body">

                <table class="table table-bordered align-middle">

                    <thead class="table-dark">

                        <tr>
                            <th>Hình ảnh</th>
                            <th>Sản phẩm</th>
                            <th>Đơn giá</th>
                            <th width="180">Số lượng</th>
                            <th>Thành tiền</th>
                            <th width="120">Xóa</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td width="120">

                                    <img src="@(string.IsNullOrEmpty(item.Product?.ImageUrl)
                                    ? "https://via.placeholder.com/100"
                                    : item.Product.ImageUrl)"
                                         width="100"
                                         height="100"
                                         style="object-fit:cover;" />

                                </td>

                                <td>
                                    @item.Product?.Name
                                </td>

                                <td>
                                    @((item.Product?.Price ?? 0).ToString("N0")) VNĐ
                                </td>

                                <td>

                                    <div class="d-flex justify-content-center">

                                        <a asp-action="Decrease"
                                           asp-route-id="@item.Id"
                                           class="btn btn-warning btn-sm">

                                            -

                                        </a>

                                        <span class="mx-3 fw-bold">

                                            @item.Quantity

                                        </span>

                                        <a asp-action="Increase"
                                           asp-route-id="@item.Id"
                                           class="btn btn-success btn-sm">

                                            +

                                        </a>

                                    </div>

                                </td>

                                <td class="fw-bold text-danger">

                                    @(((item.Product?.Price ?? 0) * item.Quantity).ToString("N0")) VNĐ

                                </td>

                                <td>

                                    <a asp-action="Remove"
                                       asp-route-id="@item.Id"
                                       class="btn btn-danger btn-sm">

                                        Xóa

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

        <div class="row mt-4">

            <div class="col-md-6">

                <div class="card shadow border-0">

                    <div class="card-header bg-info text-white">

                        Voucher

                    </div>

                    <div class="card-body">

                        <input type="text"
                               class="form-control mb-2"
                               placeholder="Nhập mã giảm giá" />

                        <button class="btn btn-info text-white">

                            Áp dụng

                        </button>

                    </div>

                </div>

            </div>

            <div class="col-md-6">

                <div class="card shadow border-0">

                    <div class="card-header bg-success text-white">

                        Tóm tắt đơn hàng

                    </div>

                    <div class="card-body">

                        <h5>

                            Tổng tiền:

                            <span class="text-danger">

                                @ViewBag.Total.ToString("N0") VNĐ

                            </span>

                        </h5>

                        <hr />

                        <a asp-action="Checkout"
                           class="btn btn-success w-100">

                            Thanh toán

                        </a>

                    </div>

                </div>

            </div>

        </div>
    }
    else
    {
        <div class="alert alert-info">

            Chưa có sản phẩm nào trong giỏ hàng.

        </div>

        <a asp-controller="Product"
           asp-action="Index"
           class="btn btn-primary">

            Tiếp tục mua sắm

        </a>
    }
    ```

</div>
